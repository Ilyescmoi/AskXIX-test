# Copie ce fichier en .env (ou exporte ces variables) puis renseigne ta clé.
# La clé n'est JAMAIS écrite en dur dans le code.

# Clé API Mistral (ou tout fournisseur compatible chat-completions).
MISTRAL_API_KEY=

# Optionnel : endpoint compatible OpenAI/Mistral (utile pour un modèle open-source local).
MISTRAL_ENDPOINT=https://api.mistral.ai/v1/chat/completions

# Optionnel : modèle utilisé pour la classification.
MISTRAL_MODEL=mistral-small-latest
